            if canonical in processed_canonicals:
                continue

            # Simple optimization: If no aliases, skip
            if not aliases:
                continue
                
            print(f"[{processed_count+1}] Auditing: {canonical} ({len(aliases)} aliases)")
            agent.audit_canonical(group, canonical, aliases)
            processed_count += 1
            
